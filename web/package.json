{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build && node scripts/harden-spa-fallback.mjs && node scripts/relocate-under-base.mjs",
    "typecheck": "react-router typegen && tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "check:research:style": "node scripts/check-research-style.mjs",
    "check:research:links": "node scripts/check-research-links.mjs",
    "check:research:citations": "node scripts/check-research-citations.mjs",
    "check:research:hardware": "node scripts/check-research-hardware.mjs",
    "check:research": "npm run check:research:style && npm run check:research:links && npm run check:research:citations && node scripts/check-research-anchors.mjs && node scripts/check-research-hardware.mjs && node scripts/check-research-parity.mjs",
    "check:research:ci": "node scripts/check-research-style.mjs && node scripts/check-research-links.mjs && node scripts/check-research-citations.mjs --no-fetch && node scripts/check-research-anchors.mjs && node scripts/check-research-hardware.mjs && node scripts/check-research-parity.mjs",
    "indexnow": "node scripts/indexnow-submit.mjs",
    "check:research:anchors": "node scripts/check-research-anchors.mjs",
    "check:research:parity": "node scripts/check-research-parity.mjs",
    "check:i18n": "node scripts/check-i18n-coverage.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@react-router/node": "7.17.0",
    "@shikijs/rehype": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "isbot": "^5",
    "katex": "^0.17.0",
    "lucide-react": "^1.18.0",
    "minisearch": "^7.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.17.0",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "7.17.0",
    "@types/katex": "^0.16.8",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "shadcn": "^4.11.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3",
    "@playwright/test": "^1.61.1"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.3"
  },
  "packageManager": "pnpm@9.2.0"
}
