# Shared research experiments. Invoked from the repo root as a just module:
#
#   just experiments                          # list the experiments
#   just experiments single-core-benchmark    # run one
#
# Recipes run with this directory as the working directory, so paths are
# relative to research/experiments/. Each experiment is a self-contained
# subdirectory; any researcher's work can be added here.

# List the runnable experiments (default).
default:
    @just --list

# Single-core solver benchmark: build + run all 17 solvers (native + strong),
# regenerate the report, and regenerate the site JSON the research page reads.
single-core-benchmark budget_s="60" parallel="6":
    cargo build --release --manifest-path single-core-benchmark/engine/Cargo.toml --bin run_algo
    python3 single-core-benchmark/scripts/run_grid.py \
        --variants single-core-benchmark/variants \
        --out single-core-benchmark/results/rerun \
        --budget-s {{budget_s}} --seed 1 --parallel {{parallel}}
    python3 single-core-benchmark/scripts/make_report.py \
        --run single-core-benchmark/results/rerun
    python3 single-core-benchmark/scripts/make_site_json.py \
        --run single-core-benchmark/results/rerun

# DFS study: build the from-scratch backtracker family, run every runnable
# variant on the ten corner-pinned variants (single core, fixed budget), and
# regenerate the report and the site JSON the study page reads.
dfs-study budget_s="60" parallel="6":
    cargo build --release --manifest-path dfs-study/engine/Cargo.toml
    python3 dfs-study/scripts/run_grid.py \
        --variants dfs-study/variants \
        --out dfs-study/results/rerun \
        --budget-s {{budget_s}} --seed 1 --parallel {{parallel}}
    python3 dfs-study/scripts/make_report.py \
        --run dfs-study/results/rerun
    python3 dfs-study/scripts/make_site_json.py \
        --run dfs-study/results/rerun

# Repair study: build the from-scratch destroy-and-repair (local search) family,
# run every variant on the ten corner-pinned variants (single core, fixed
# budget), and regenerate the report and the site JSON the study page reads. The
# board, scorer and IO come from the shared ../common library (also used by the
# DFS study), so a repaired board is scored by the exact same scorer.
repair-study budget_s="60" parallel="6":
    cargo build --release --manifest-path repair-study/engine/Cargo.toml
    python3 repair-study/scripts/run_grid.py \
        --variants repair-study/variants \
        --out repair-study/results/rerun \
        --budget-s {{budget_s}} --seed 1 --parallel {{parallel}}
    python3 repair-study/scripts/make_report.py \
        --run repair-study/results/rerun
    python3 repair-study/scripts/make_site_json.py \
        --run repair-study/results/rerun

# Hint study: build the parametric board generator and the DFS fill-path family,
# then run every fill path on every hint geometry across many seeded instances
# (single core per run, `--parallel`-wide), and regenerate the site JSON the
# study pages read. The generator lives in the site engine; the solvers are the
# DFS study's backtracker and the benchmark's beam, so a hinted board is scored
# by the same canonical scorer as every other study.
hint-study budget_s="8" parallel="6" seeds="15":
    # hint_variants = parametric board+hint generator; hint_scale = the runtime-
    # sized solver (one binary, any board size) for the scaling axis; run_dfs = the
    # compile-time 16×16 backtracker (fast) that backs the core study; producer_trie
    # = the beam contrast. run_dfs is built WITHOUT a size feature (=16×16).
    cargo build --release --manifest-path ../../engine/Cargo.toml --bin hint_variants --bin hint_scale
    cargo build --release --manifest-path dfs-study/engine/Cargo.toml --bin run_dfs
    cargo build --release --manifest-path single-core-benchmark/engine/Cargo.toml --bin producer_trie
    python3 hint-study/scripts/run_grid.py \
        --out hint-study/results/rerun \
        --budget-s {{budget_s}} --seeds {{seeds}} --parallel {{parallel}}
    python3 hint-study/scripts/make_site_json.py \
        --run hint-study/results/rerun

# BANDSAW (analysis tool, not a solver): prove the optimal completion of a
# board's endgame band by meet-in-the-middle. Runs the committed worked example.
bandsaw rung_ms="15000" label_ms="1500":
    cargo build --release \
        --manifest-path single-core-benchmark/engine/Cargo.toml \
        --bin mini_e2 --bin dump_board_json
    single-core-benchmark/engine/target/release/dump_board_json \
        "$(python3 -c 'import json;print(json.load(open("bandsaw/example/board.json"))["url"])')" \
        > /tmp/bandsaw_raw.json
    python3 bandsaw/scripts/to_entry.py /tmp/bandsaw_raw.json > /tmp/bandsaw_entry.json
    single-core-benchmark/engine/target/release/mini_e2 \
        --entry /tmp/bandsaw_entry.json --rung-ms {{rung_ms}} --label-ms {{label_ms}} \
        | tee bandsaw/results/bracket.json
