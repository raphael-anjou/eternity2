# Static serving for the Eternity II community site.
#
# The app is pre-rendered to a real .html file per route × language (clean
# paths like /algorithms and /fr/algorithms — no hash routing). nginx serves
# those files directly; anything it can't match falls back to the React Router
# SPA shell so client-side routing can still resolve the URL.
#
# This is a TEMPLATE: the nginx image's entrypoint runs envsubst over it at
# container start, substituting ${BASE_PATH}. For the default root deploy
# BASE_PATH is empty and every ${BASE_PATH} vanishes, giving a plain root
# config. For a path-prefix deploy (e.g. BASE_PATH=/eternity2) the whole built
# site lives under /eternity2/ on disk (the build relocates it there), so the
# asset-cache location and the SPA fallback must carry the prefix too — that is
# what these ${BASE_PATH} insertions do. NGINX_ENVSUBST_FILTER=BASE_PATH (set in
# the Dockerfile) restricts substitution to ${BASE_PATH} only, so nginx's own
# $uri variables are written plainly and pass through untouched.

server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # WASM must be served with the right MIME type for streaming compilation.
    # text/markdown for the raw-markdown research siblings (…/research/*.md) that
    # the build emits for LLMs/crawlers, so they render as text rather than
    # downloading as application/octet-stream.
    types {
        application/wasm wasm;
        text/markdown md;
    }
    include /etc/nginx/mime.types;

    gzip on;
    gzip_types text/css application/javascript application/wasm application/json image/svg+xml;
    gzip_min_length 1024;

    # Hashed build assets are immutable; index.html must always revalidate.
    location ${BASE_PATH}/assets/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
    }
    location = ${BASE_PATH}/index.html {
        add_header Cache-Control "no-cache";
    }
    # Serve the pre-rendered file for a path; if none exists, hand the request
    # to the SPA shell (which lives under the prefix for a prefixed build) and
    # let the client router resolve it.
    location / {
        try_files $uri $uri/ $uri.html ${BASE_PATH}/__spa-fallback.html =404;
    }
}
